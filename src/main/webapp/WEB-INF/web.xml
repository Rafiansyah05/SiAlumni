<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>SiAlumni</display-name>

    <!-- Welcome file - halaman pertama yang dibuka -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>



    <!-- Session timeout 30 menit -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Konfigurasi koneksi database / Supabase -->
    <context-param>
        <param-name>db.url</param-name>
        <param-value>jdbc:postgresql://db.tereexilkchduyiclgoy.supabase.co:6543/postgres?sslmode=require</param-value>
    </context-param>
    <context-param>
        <param-name>db.user</param-name>
        <param-value>postgres</param-value>
    </context-param>
    <context-param>
        <param-name>db.pass</param-name>
        <param-value>SiAlumni567#</param-value>
    </context-param>
    <context-param>
        <param-name>supabase.apiKey</param-name>
        <param-value>YOUR_SUPABASE_API_KEY</param-value>
    </context-param>

    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/views/public/index.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/public/index.jsp</location>
    </error-page>

</web-app>
